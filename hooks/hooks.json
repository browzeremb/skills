{
  "hooks": {
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BROWZER PLUGIN: this repo is indexed by Browzer (hybrid vector + Graph RAG). SEARCH (strongest rule — cannot be hook-enforced, so read carefully): before writing or modifying ANY code that touches a library, framework, configuration syntax, or API you did not write yourself, you MUST first call `browzer search \"<topic>\" --save /tmp/search.json`. Heuristic: if you would normally consult documentation, your training data, or Stack Overflow — search browzer FIRST. Your training data may be stale or not match this project version. If mid-reasoning you catch yourself forming an opinion about how a library works, STOP and search before continuing. Do NOT pretend you searched when you did not — the file /tmp/search.json is the receipt. EXPLORE: for questions about code inside this repo (where is X / how does Y work / what imports Z), use `browzer explore \"<q>\" --save /tmp/explore.json` instead of Glob/Grep/find. Read on indexed code is auto-rewritten via the daemon for token-economy.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BROWZER PLUGIN active.'; browzer status --json 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-session-start.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-rewrite-bash.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-contract.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-init.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/commit-coauthor.mjs\""
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-rewrite-read.mjs\""
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-block-glob.mjs\""
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-suggest-grep.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/browzer-sync-on-push.mjs\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/auto-format.mjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/user-prompt-browzer-search.mjs\""
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/quality-gate-context.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guards/quality-gate-stop.mjs\""
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/orchestrator-autochain.py\""
          }
        ]
      }
    ]
  }
}
